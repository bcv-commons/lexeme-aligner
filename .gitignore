out/
__pycache__/
*.egg-info/
*.pyc
# local secrets (HF token, DBT API key, ...) — never committed
.env
# copied-in spine.db / hbo.db — provided out-of-band, never committed
*.db
# private working notes / handover — not official (Claude auto-loads it)
CLAUDE.local.md
# copied-in target Bibles (USJ) — pilot text, provided out-of-band
data/usj-*/
# copied-in bcv-commons/strongs datasets (gold attestations, gloss priors)
data/resources/
# lexeme-alignments bulk data — regenerated per language, published out-of-band (HF / object storage).
# Only manifest.json + README.md stay in git (see lexeme-alignments/README.md).
lexeme-alignments/iso=*/
# local cache of sha256s last successfully pushed per (repo, path) — avoids re-uploading unchanged
# shared files (manifest/README/companions) on every language in a publish batch (export_lex.py).
.publish_state.json
# CDN PKF download cache — bulk, re-fetched by pin
data/_pool/
# Node edge converter deps (PKF->USFM) — installed locally, not committed
pkf2usfm/node_modules/
# karnbibeln lexicon cache (scraped reference for the diff test)
data/karnbibeln/
# senses_attested bulk data — same as lexeme-alignments; only manifest.json committed
senses_attested/iso=*/
# aligned_mwe bulk data (contiguous multi-word expressions) — same pattern; only manifest.json committed
aligned_mwe/iso=*/
internal-docs/
# prior-pack pulled from bcv-commons/prior-pack (HF, CC-BY) — bulk parquet + HF cache git-ignored;
# resources/prior-pack/manifest.json + README.md stay tracked as the version pin (see PROVENANCE).
resources/prior-pack/*.parquet
resources/prior-pack/.cache/
resources/prior-pack/.gitattributes
# one-off debug/ablation/probe scripts — never committed; scripts/ itself holds only durable recipes
# (+ scripts/archive/ for superseded historical batch runs, kept as provenance)
scripts/adhoc/
# target-morphology bulk data — same pattern as lexeme-alignments; only manifest.json + README.md committed
data/morph/*.json
!data/morph/manifest.json
# target-stopwords bulk data — same pattern
data/stopwords/*.txt
# cross-lingual-span-profile bulk data — same pattern
resources/cross_lang_prior/profile.json
resources/cross_lang_prior/light_lexemes.json
# globalbibletools/data seeded copy — provided out-of-band, pinned commit in PROVENANCE.txt
data/gbt/
# occurrence-alignment extraction output (gbt + bsb) — bulk, regenerated from data/gbt/ + data/bsb/
resources/occurrence_align/
# BSB-publishing/bsb-data-output fetched copy — provided out-of-band, pinned commit in PROVENANCE.txt
data/bsb/
